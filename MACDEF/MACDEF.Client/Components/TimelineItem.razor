@namespace MACDEF.Client.Components

<div class="flex gap-8">
    <div class="flex flex-col items-center flex-shrink-0">
        <div class="w-12 h-12 bg-[#8B4513] text-white rounded-full flex items-center justify-center font-bold">
            <i class="ri-check-line"></i>
        </div>
        <div class="w-1 h-24 bg-[#D2691E] mt-4"></div>
    </div>
    <div class="pb-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-2">@Year</h3>
        <h4 class="text-xl font-semibold text-[#8B4513] mb-4">@Title</h4>
        <ul class="space-y-2">
            @foreach (var item in Items)
            {
                <li class="flex items-center text-gray-700">
                    <span class="w-2 h-2 bg-[#D2691E] rounded-full mr-3"></span>
                    @item
                </li>
            }
        </ul>
    </div>
</div>

@code {
    [Parameter]
    public string Year { get; set; } = "";

    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public List<string> Items { get; set; } = new();
}
