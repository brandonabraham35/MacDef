@namespace MACDEF.Client.Components

<div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition">
    <div class="flex items-start justify-between mb-4">
        <div>
            <h3 class="text-xl font-bold text-gray-800">@Title</h3>
            <p class="text-sm text-[#8B4513] font-semibold flex items-center mt-2">
                <i class="ri-calendar-line mr-2"></i>@Date
            </p>
        </div>
    </div>
    <p class="text-gray-600 mb-4">@Description</p>
    <a href="#" class="text-[#8B4513] font-semibold hover:text-[#A0522D] transition flex items-center">
        Learn More <i class="ri-arrow-right-line ml-2"></i>
    </a>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string Date { get; set; } = "";

    [Parameter]
    public string Description { get; set; } = "";
}
