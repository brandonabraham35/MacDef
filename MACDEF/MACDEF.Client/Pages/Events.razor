@page "/events"
@namespace MACDEF.Client.Pages

<div class="bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl font-bold mb-4">Community Events</h1>
        <p class="text-lg text-gray-100">Celebrate, Learn, and Connect</p>
    </div>
</div>

<main class="max-w-6xl mx-auto py-16 px-6">
    <div class="mb-12">
        <p class="text-lg text-gray-700 text-center">
            Join us for celebrations, educational workshops, cultural performances, and community gatherings that bring the Ma'di family together.
        </p>
    </div>

    <!-- Upcoming Events -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-gray-900">Upcoming Events</h2>
        <div class="grid md:grid-cols-2 gap-8">
            <EventCard 
                Title="Annual Cultural Festival" 
                Date="June 15-17, 2024" 
                Description="The flagship event celebrating Ma'di heritage with traditional music, dance, food, crafts, and storytelling. A vibrant gathering of community members and guests from around the world." />

            <EventCard 
                Title="Youth Leadership Summit" 
                Date="July 22, 2024" 
                Description="Empowering young Ma'di leaders to take active roles in community development. Featuring workshops on cultural preservation, entrepreneurship, and community advocacy." />

            <EventCard 
                Title="Cultural Activities & Elders Council" 
                Date="August 10, 2024" 
                Description="Traditional narratives and wisdom sharing from our respected elders. Learn about historical events, cultural practices, and life lessons that have shaped our community." />

            <EventCard 
                Title="Ma'di Language Classes" 
                Date="Every Saturday, 10 AM" 
                Description="Learn the beautiful Ma'di language from experienced community members. Classes for beginners through advanced learners, designed for all ages." />

            <EventCard 
                Title="Traditional Arts Workshop" 
                Date="August 25, 2024" 
                Description="Hands-on training in traditional Ma'di crafts, beadwork, weaving, and artistic expressions. Taught by master artisans within our community." />

            <EventCard 
                Title="Community Thanksgiving" 
                Date="September 5, 2024" 
                Description="A celebration of gratitude bringing the community together with music, feasting, and thanksgiving to our ancestors and cultural heritage." />
        </div>
    </section>

    <!-- Past Events Gallery -->
    <section class="bg-gray-100 rounded-lg p-12">
        <h2 class="text-3xl font-bold mb-8 text-gray-900">Recent Events</h2>
        <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
                <div class="bg-gray-300 h-48 flex items-center justify-center">
                    <img src="event1.jpg" alt="Previous event" class="w-full h-full object-cover" />
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold mb-2 text-gray-900">Cultural Expo 2023</h3>
                    <p class="text-gray-600 text-sm">A successful showcase of Ma'di crafts, traditional knowledge, and contemporary innovations.</p>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
                <div class="bg-gray-300 h-48 flex items-center justify-center">
                    <img src="event2.jpg" alt="Previous event" class="w-full h-full object-cover" />
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold mb-2 text-gray-900">Youth Mentorship Program</h3>
                    <p class="text-gray-600 text-sm">Connected young professionals with community leaders for guidance and development.</p>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
                <div class="bg-gray-300 h-48 flex items-center justify-center">
                    <img src="event3.jpg" alt="Previous event" class="w-full h-full object-cover" />
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold mb-2 text-gray-900">Heritage Documentation</h3>
                    <p class="text-gray-600 text-sm">Successfully documented oral histories and cultural practices for future generations.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Registration CTA -->
    <section class="mt-16 bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white rounded-lg p-12 text-center">
        <h2 class="text-3xl font-bold mb-4">Don't Miss Out!</h2>
        <p class="text-lg mb-8">Register for upcoming events and stay connected with the Ma'di community.</p>
        <a href="/contact" class="bg-white text-[#8B4513] px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
            Register Now
        </a>
    </section>
</main>

