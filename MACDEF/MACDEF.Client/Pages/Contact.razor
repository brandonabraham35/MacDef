@page "/contact"
@namespace MACDEF.Client.Pages
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using System.Text

<PageTitle>Contact Us - MACDEF</PageTitle>

<div class="bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl font-bold mb-4">Contact Us</h1>
        <p class="text-lg text-gray-100">We'd love to hear from you</p>
    </div>
</div>

<main class="max-w-4xl mx-auto py-16 px-6">
    <p class="text-lg text-gray-700 text-center mb-12">
        Whether you have a question, want to share a story, or are interested in getting involved with MACDEF, please don't hesitate to reach out.
        We're here to connect you with our vibrant Ma'di community.
    </p>

    <div class="grid md:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-lg shadow-md">
            <h2 class="text-2xl font-bold mb-6 text-gray-900">Send us a Message</h2>
            <EditForm Model="@contactForm" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />

                <div class="mb-4">
                    <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">First Name *</label>
                    <InputText id="firstName" @bind-Value="contactForm.FirstName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#8B4513] focus:border-transparent" />
                    <ValidationMessage For="@(() => contactForm.FirstName)" />
                </div>

                <div class="mb-4">
                    <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">Last Name *</label>
                    <InputText id="lastName" @bind-Value="contactForm.LastName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#8B4513] focus:border-transparent" />
                    <ValidationMessage For="@(() => contactForm.LastName)" />
                </div>

                <div class="mb-4">
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
                    <InputText id="email" type="email" @bind-Value="contactForm.Email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#8B4513] focus:border-transparent" />
                    <ValidationMessage For="@(() => contactForm.Email)" />
                </div>

                <div class="mb-4">
                    <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                    <InputText id="phone" @bind-Value="contactForm.Phone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#8B4513] focus:border-transparent" />
                </div>

                <div class="mb-4">
                    <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">Subject *</label>
                    <InputSelect id="subject" @bind-Value="contactForm.Subject" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#8B4513] focus:border-transparent">
                        <option value="">Select a subject...</option>
                        <option value="inquiry">General Inquiry</option>
                        <option value="membership">Membership</option>
                        <option value="volunteer">Volunteer Opportunity</option>
                        <option value="event">Event Registration</option>
                        <option value="partnership">Partnership Opportunity</option>
                        <option value="other">Other</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => contactForm.Subject)" />
                </div>

                <div class="mb-6">
                    <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message *</label>
                    <InputTextArea id="message" @bind-Value="contactForm.Message" rows="6" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#8B4513] focus:border-transparent" />
                    <ValidationMessage For="@(() => contactForm.Message)" />
                </div>

                @if (submitMessage != null)
                {
                    <div class="mb-4 p-4 rounded-lg whitespace-pre-wrap @(isSuccess ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                        @submitMessage
                    </div>
                }

                <button type="submit" class="w-full bg-[#8B4513] text-white font-semibold py-3 rounded-lg hover:bg-[#A0522D] transition" disabled="@isSubmitting">
                    @(isSubmitting ? "Sending..." : "Send Message")
                </button>
            </EditForm>

            <div class="mt-4 text-sm text-gray-600">
                Prefer email? <a href="mailto:macdef2013@gmail.com?subject=MACDEF%20Website%20Inquiry" class="font-semibold text-[#8B4513]">Send us a mail directly</a>.
            </div>
        </div>

        <div>
            <div class="bg-white p-8 rounded-lg shadow-md mb-8">
                <h2 class="text-2xl font-bold mb-6 text-gray-900">Get In Touch</h2>

                <div class="mb-8">
                    <h3 class="text-lg font-semibold text-[#8B4513] mb-2 flex items-center">
                        <i class="ri-map-pin-line mr-3 text-2xl"></i> Location
                    </h3>
                    <p class="text-gray-700">
                        Ma'di Cultural and Development Foundation<br/>
                        Namataba, Kirinya<br/>
                        Bweyogerere, Wakiso District<br/>
                        Uganda
                    </p>
                </div>

                <div class="mb-8">
                    <h3 class="text-lg font-semibold text-[#8B4513] mb-2 flex items-center">
                        <i class="ri-mail-box-line mr-3 text-2xl"></i> Mailing Address
                    </h3>
                    <p class="text-gray-700">
                        P.O. Box 137214<br/>
                        Kampala, Uganda
                    </p>
                </div>

                <div class="mb-8">
                    <h3 class="text-lg font-semibold text-[#8B4513] mb-2 flex items-center">
                        <i class="ri-phone-line mr-3 text-2xl"></i> Phone
                    </h3>
                    <div class="text-gray-700 space-y-2">
                        <p><a href="tel:+256772590948" class="hover:text-[#8B4513] transition">+256 772 590 948</a></p>
                        <p><a href="tel:+256772386881" class="hover:text-[#8B4513] transition">+256 772 386 881</a></p>
                        <p><a href="tel:+256789924916" class="hover:text-[#8B4513] transition">+256 789 924 916</a></p>
                        <p><a href="tel:+256774881914" class="hover:text-[#8B4513] transition">+256 774 881 914</a></p>
                    </div>
                </div>

                <div class="mb-8">
                    <h3 class="text-lg font-semibold text-[#8B4513] mb-2 flex items-center">
                        <i class="ri-mail-line mr-3 text-2xl"></i> Email
                    </h3>
                    <p class="text-gray-700">
                        <a href="mailto:macdef2013@gmail.com" class="hover:text-[#8B4513] transition">macdef2013@gmail.com</a>
                    </p>
                </div>
            </div>

            <div class="bg-gray-100 p-8 rounded-lg">
                <h2 class="text-2xl font-bold mb-6 text-gray-900">Office Hours</h2>
                <div class="space-y-3 text-gray-700">
                    <p><strong>Monday - Friday:</strong> 9:00 AM - 5:00 PM</p>
                    <p><strong>Saturday:</strong> 10:00 AM - 2:00 PM</p>
                    <p><strong>Sunday:</strong> Closed</p>
                </div>
            </div>
        </div>
    </div>
</main>

@code {
    [Inject]
    private HttpClient ApiHttp { get; set; } = default!;

    private ContactFormModel contactForm = new();
    private string? submitMessage;
    private bool isSuccess;
    private bool isSubmitting;

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        submitMessage = null;

        try
        {
            var content = new FormUrlEncodedContent(new Dictionary<string, string?>
            {
                ["FirstName"] = contactForm.FirstName,
                ["LastName"] = contactForm.LastName,
                ["Email"] = contactForm.Email,
                ["Phone"] = contactForm.Phone,
                ["Subject"] = contactForm.Subject,
                ["Message"] = contactForm.Message
            }!);

            var response = await ApiHttp.PostAsync("/api/contact", content);
            var responseBody = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ContactSubmissionResponse>();
                submitMessage = result?.Message ?? "Thank you for reaching out! Your message was received.";
                isSuccess = true;
                contactForm = new();
                return;
            }

            submitMessage = string.IsNullOrWhiteSpace(responseBody)
                ? $"An error occurred while sending your message. Server returned {(int)response.StatusCode}."
                : responseBody;
            isSuccess = false;
        }
        catch (Exception ex)
        {
            submitMessage = $"An error occurred while sending your message. {ex.Message}";
            isSuccess = false;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class ContactFormModel
    {
        [Required(ErrorMessage = "First name is required")]
        public string FirstName { get; set; } = "";
        [Required(ErrorMessage = "Last name is required")]
        public string LastName { get; set; } = "";
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        [Required(ErrorMessage = "Please select a subject")]
        public string Subject { get; set; } = "";
        [Required(ErrorMessage = "Message is required")]
        [StringLength(1000, MinimumLength = 10, ErrorMessage = "Message must be between 10 and 1000 characters")]
        public string Message { get; set; } = "";
    }

    public record ContactSubmissionResponse(bool Success, string Message);
}
