@page "/privacy"
@namespace MACDEF.Client.Pages

<PageTitle>Privacy Policy - MACDEF</PageTitle>

<section class="bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl font-bold mb-4">Privacy Policy</h1>
        <p class="text-lg text-gray-100">How MACDEF handles information shared through this website</p>
    </div>
</section>

<main class="max-w-4xl mx-auto py-16 px-6">
    <div class="bg-white rounded-2xl shadow-lg p-8 md:p-10">
        <div class="space-y-6 text-gray-700 leading-7">
            <p>
                This website is operated by Ma'di Cultural and Development Foundation (MACDEF). We respect your privacy and only collect information you choose to submit through our contact form or other communication channels.
            </p>

            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-3">Information We Collect</h2>
                <p>Name, email address, phone number, subject, and message content submitted via the contact form.</p>
            </div>

            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-3">How We Use Information</h2>
                <p>We use submitted information to respond to inquiries, support membership and collaboration requests, and improve communication with our community.</p>
            </div>

            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-3">Sharing</h2>
                <p>We do not sell your personal information. We only share it when necessary to respond to your request or where required by law.</p>
            </div>

            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-3">Contact</h2>
                <p>If you have privacy questions, contact us at <a href="mailto:macdef2013@gmail.com">macdef2013@gmail.com</a>.</p>
            </div>
        </div>
    </div>
</main>
