@namespace MACDEF.Client

<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not Found</PageTitle>
        <LayoutView Layout="typeof(MainLayout)">
            <div class="max-w-4xl mx-auto py-16 px-6 text-center">
                <h1 class="text-4xl font-bold text-gray-900 mb-4">Page Not Found</h1>
                <p class="text-lg text-gray-700 mb-8">The page you're looking for doesn't exist.</p>
                <a href="/" class="bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-light transition">
                    Go Home
                </a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
