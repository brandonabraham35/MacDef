<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MACDEF - Ma'di Cultural and Development Foundation</title>
    <meta name="description" content="Ma'di Cultural and Development Foundation (MACDEF) - preserving heritage, promoting language, and building community development." />
    <meta name="keywords" content="MACDEF, Ma'di, cultural foundation, Uganda, heritage, language, community development" />
    <meta name="author" content="Ma'di Cultural and Development Foundation" />
    <meta name="theme-color" content="#8B4513" />
    <meta property="og:title" content="MACDEF - Ma'di Cultural and Development Foundation" />
    <meta property="og:description" content="Preserving heritage, building community, and supporting cultural development." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/macdef-logo.png" />
    <link rel="icon" href="/macdef-logo.png" type="image/png" />

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#8B4513',
                        'primary-light': '#A0522D',
                        secondary: '#D2691E',
                        accent: '#CD853F'
                    },
                    borderRadius: {
                        'button': '8px'
                    },
                    fontFamily: {
                        'inter': ['Inter', 'sans-serif']
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Pacifico&display=swap" rel="stylesheet" />

    <!-- Remix Icon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.6.0/remixicon.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="app.css" />

    <base href="/" />
</head>
<body class="bg-gray-50 font-inter">
    <div id="app">
        <div id="app-loading" class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#8B4513] to-[#D2691E] text-white">
            <div class="flex flex-col items-center gap-4">
                <div class="spinner"></div>
                <div class="loading-text">Loading MACDEF...</div>
                <div class="error-text" id="error-message" style="display:none;"></div>
            </div>
        </div>
    </div>

    <script src="_framework/blazor.webassembly.js"></script>

    <script>
        console.log('Page loaded, waiting for Blazor...');

        document.addEventListener('DOMContentLoaded', function () {
            const loading = document.getElementById('app-loading');
            if (loading) {
                loading.style.display = 'flex';
            }
        });

        window.addEventListener('error', function (e) {
            console.error('Global error:', e.message, e.filename, e.lineno, e.colno, e.error);
            const errorDiv = document.getElementById('error-message');
            if (errorDiv) {
                errorDiv.style.display = 'block';
                errorDiv.textContent = 'Error loading application. Check browser console for details.';
            }
        });

        window.addEventListener('unhandledrejection', function (e) {
            console.error('Unhandled rejection:', e.reason);
        });
    </script>
</body>
</html>
