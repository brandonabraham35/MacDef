@tailwind base;
@tailwind components;
@tailwind utilities;

/* Custom color scheme */
:root {
    --primary: #8B4513;
    --primary-light: #A0522D;
    --secondary: #D2691E;
    --accent: #CD853F;
    --text-main: #1F2937;
    --text-muted: #4B5563;
    --bg-light: #F9FAFB;
    --bg-white: #FFFFFF;
}

/* Smooth scrolling */
html {
    scroll-behavior: smooth;
}

/* Custom animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

/* Utility classes */
.fade-in-up {
    animation: fadeInUp 0.6s ease-out;
}

.fade-in {
    animation: fadeIn 0.6s ease-out;
}

/* Navigation styles */
.nav-link {
    position: relative;
}

.nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 0.125rem;
    background-color: var(--primary);
    transition: width 0.3s ease-out;
}

.nav-link:hover::after {
    width: 100%;
}

/* Button styles */
.btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-primary {
    background-color: var(--primary);
    color: white;
}

.btn-primary:hover {
    background-color: var(--primary-light);
}

.btn-secondary {
    border: 2px solid var(--primary);
    color: var(--primary);
}

.btn-secondary:hover {
    background-color: var(--primary);
    color: white;
}

/* Card hover effect */
.card-hover {
    transition: all 0.3s ease;
}

.card-hover:hover {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    transform: scale(1.05);
}

/* Gradient backgrounds */
.gradient-primary {
    background: linear-gradient(to right, var(--primary), var(--secondary));
}

/* Typography enhancements */
h1, h2, h3, h4, h5, h6 {
    font-weight: bold;
    color: #111827;
}

p {
    color: #374151;
    line-height: 1.625;
}

/* Link styles */
a {
    color: var(--primary);
    transition: color 0.2s ease;
}

a:hover {
    color: var(--primary-light);
}

/* Form styles */
input:focus,
textarea:focus,
select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
}

/* Validation error styles */
.validation-error {
    color: #DC2626;
    font-size: 0.875rem;
    margin-top: 0.25rem;
}

/* Dropdown menu */
.dropdown-menu {
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
}

.dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
}

/* Footer */
footer {
    border-top: 1px solid #E5E7EB;
    margin-top: auto;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .nav-items {
        flex-direction: column;
        gap: 1rem;
    }

    h1 {
        font-size: 1.875rem;
    }

    h2 {
        font-size: 1.5rem;
    }
}
