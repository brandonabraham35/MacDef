@namespace MACDEF.Client.Components.Layout

<footer class="bg-gray-900 text-gray-300 mt-20">
    <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid md:grid-cols-4 gap-8 mb-12">
            <!-- About Section -->
            <div>
                <h3 class="text-white font-bold text-lg mb-4">About MACDEF</h3>
                <p class="text-sm text-gray-400">
                    Madi Cultural Development Foundation is dedicated to preserving and promoting Madi cultural heritage.
                </p>
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="text-white font-bold text-lg mb-4">Quick Links</h3>
                <ul class="text-sm space-y-2">
                    <li><a href="/" class="text-gray-400 hover:text-white transition">Home</a></li>
                    <li><a href="/about" class="text-gray-400 hover:text-white transition">About Us</a></li>
                    <li><a href="/events" class="text-gray-400 hover:text-white transition">Events</a></li>
                    <li><a href="/contact" class="text-gray-400 hover:text-white transition">Contact</a></li>
                </ul>
            </div>

            <!-- Resources -->
            <div>
                <h3 class="text-white font-bold text-lg mb-4">Resources</h3>
                <ul class="text-sm space-y-2">
                    <li><a href="/photo-gallery" class="text-gray-400 hover:text-white transition">Gallery</a></li>
                    <li><a href="/documents" class="text-gray-400 hover:text-white transition">Documents</a></li>
                    <li><a href="/research" class="text-gray-400 hover:text-white transition">Research</a></li>
                    <li><a href="/library" class="text-gray-400 hover:text-white transition">Library</a></li>
                </ul>
            </div>

            <!-- Contact Info -->
            <div>
                <h3 class="text-white font-bold text-lg mb-4">Contact</h3>
                <p class="text-sm text-gray-400 mb-2">
                    <i class="ri-map-pin-line mr-2"></i>Location
                </p>
                <p class="text-sm text-gray-400 mb-2">
                    <i class="ri-phone-line mr-2"></i>+256 XXX XXX XXX
                </p>
                <p class="text-sm text-gray-400">
                    <i class="ri-mail-line mr-2"></i>info@macdef.org
                </p>
            </div>
        </div>

        <div class="border-t border-gray-700 pt-8">
            <div class="flex justify-between items-center">
                <p class="text-sm text-gray-400">
                    &copy; 2024 Madi Cultural Development Foundation. All rights reserved.
                </p>
                <div class="flex space-x-4">
                    <a href="#" class="text-gray-400 hover:text-white transition">
                        <i class="ri-facebook-fill"></i>
                    </a>
                    <a href="#" class="text-gray-400 hover:text-white transition">
                        <i class="ri-twitter-fill"></i>
                    </a>
                    <a href="#" class="text-gray-400 hover:text-white transition">
                        <i class="ri-instagram-fill"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>

