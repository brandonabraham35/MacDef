@tailwind base;
@tailwind components;
@tailwind utilities;

/* Custom color scheme */
:root {
    --primary: #8B4513;
    --primary-light: #A0522D;
    --secondary: #D2691E;
    --accent: #CD853F;
    --text-main: #1F2937;
    --text-muted: #4B5563;
    --bg-light: #F9FAFB;
    --bg-white: #FFFFFF;
}

/* Smooth scrolling */
html {
    scroll-behavior: smooth;
}

/* Custom animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

/* Utility classes */
.fade-in-up {
    animation: fadeInUp 0.6s ease-out;
}

.fade-in {
    animation: fadeIn 0.6s ease-out;
}

/* Navigation styles */
.nav-link {
    @apply relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all after:duration-300 hover:after:w-full;
}

/* Button styles */
.btn {
    @apply inline-block px-6 py-3 rounded-lg font-semibold transition-all duration-300;
}

.btn-primary {
    @apply btn bg-primary text-white hover:bg-primary-light;
}

.btn-secondary {
    @apply btn border-2 border-primary text-primary hover:bg-primary hover:text-white;
}

/* Card hover effect */
.card-hover {
    @apply transition-all duration-300 hover:shadow-xl hover:scale-105;
}

/* Gradient backgrounds */
.gradient-primary {
    @apply bg-gradient-to-r from-primary to-secondary;
}

/* Typography enhancements */
h1, h2, h3, h4, h5, h6 {
    @apply font-bold text-gray-900;
}

p {
    @apply text-gray-700 leading-relaxed;
}

/* Link styles */
a {
    @apply text-primary hover:text-primary-light transition-colors;
}

/* Form styles */
input:focus,
textarea:focus,
select:focus {
    @apply ring-2 ring-primary ring-opacity-50 border-primary;
}

/* Validation error styles */
.validation-error {
    @apply text-red-600 text-sm mt-1;
}

/* Dropdown menu */
.dropdown-menu {
    @apply opacity-0 invisible transition-all duration-300;
}

.dropdown:hover .dropdown-menu {
    @apply opacity-100 visible;
}

/* Footer */
footer {
    @apply border-t border-gray-200;
    margin-top: auto;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .nav-items {
        @apply flex-col space-y-4;
    }

    h1 {
        @apply text-3xl;
    }

    h2 {
        @apply text-2xl;
    }
}
