@page "/goals"
@namespace MACDEF.Client.Pages

<div class="bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl font-bold mb-4">Our Goals & Strategic Objectives</h1>
        <p class="text-lg text-gray-100">Strategic direction for cultural preservation and community development</p>
    </div>
</div>

<main class="max-w-4xl mx-auto py-16 px-6">
    <!-- Goals Overview -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-6 text-gray-900">MACDEF Goals</h2>
        <div class="space-y-4 mb-12">
            <div class="border-l-4 border-[#8B4513] pl-6 py-2">
                <p class="text-lg text-gray-700">
                    <strong>Goal 1:</strong> Document, preserve and consolidate the rich cultural, social and economic heritage of the Ma'di people
                </p>
            </div>
            <div class="border-l-4 border-[#8B4513] pl-6 py-2">
                <p class="text-lg text-gray-700">
                    <strong>Goal 2:</strong> Empower and build strategic synergy as catalyst for sustainable social, cultural and economic development of the Ma'di people by adopting robust and innovative means
                </p>
            </div>
            <div class="border-l-4 border-[#8B4513] pl-6 py-2">
                <p class="text-lg text-gray-700">
                    <strong>Goal 3:</strong> Strive to ensure the Ma'di are a cohesive, organized and united community that is strategic, self-mobilizing, and in charge of their destiny
                </p>
            </div>
            <div class="border-l-4 border-[#8B4513] pl-6 py-2">
                <p class="text-lg text-gray-700">
                    <strong>Goal 4:</strong> Maintain the structure as an engaging voice for the people in events of inevitable circumstances and any form of unfairness to the Ma'di as a people
                </p>
            </div>
        </div>
    </section>

    <!-- Strategic Objectives -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">Thematic Areas & Strategic Objectives</h2>
        <div class="grid md:grid-cols-1 gap-6">
            <GoalCard
                Number="01"
                Title="History, Language, Culture, Tradition & Artistic Development"
                Description="Research and trace the heritage of the Ma'di people through their origin, language, culture and traditions. Capture, preserve and promote the usage of Ma'di language, culture, traditions, culinary, artistic designs and technology." />

            <GoalCard
                Number="02"
                Title="Community Mobilization & Liaison"
                Description="Establish a functional coordination framework to mobilize the Ma'di community living outside the region and those in the Diaspora for sustainable socio-cultural and economic development." />

            <GoalCard
                Number="03"
                Title="Education, Development of Education & Research"
                Description="Foster secular education at all levels, create, build and store knowledge, generate and disseminate on socio-cultural and socio-economic issues aimed at improving peace, justice and wellbeing of the Ma'di people." />

            <GoalCard
                Number="04"
                Title="Finance & Economic Development"
                Description="Steer the Ma'di to embrace optimum principles and practice of sustainable wealth creation and harness economic development opportunities for prosperity." />

            <GoalCard
                Number="05"
                Title="Natural Resources Management, Agro-forestry, Water & Environmental Conservation"
                Description="Promote the prudent use of the environment and natural resources for sustainable development in all sectors." />

            <GoalCard
                Number="06"
                Title="Human and Animal Health & Traditional Medicine/Ethno-botany"
                Description="Empower the Ma'di to embrace modern and traditional principles and practices of human, animal and plant health using one-health principles." />

            <GoalCard
                Number="07"
                Title="Technology, Science & Information Communication Technology (ICT)"
                Description="Document and preserve Ma'di traditional technology based on Blacksmith work, clay pottery, woodworks, fibres and other materials used by the Ma'di." />

            <GoalCard
                Number="08"
                Title="Justice, Peace & Conflict Resolution"
                Description="Revive and conserve the Ma'di traditional justice system and promote mechanisms of justice that are pro-people, pro-human rights, and consonant with the Constitution of Uganda." />

            <GoalCard
                Number="09"
                Title="Social Cohesion, Vulnerability Reduction & Socio-Economic Resilience"
                Description="Improve the livelihood of underprivileged communities by empowering them with knowledge and mobilizing resources to fight poverty, improve education and public health." />
        </div>
    </section>

    <!-- Organizational Structure -->
    <section class="bg-gray-100 rounded-lg p-12 mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center text-gray-900">MACDEF Structure</h2>
        <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3">
                    <i class="ri-team-line mr-2"></i>The General Assembly (GA)
                </h3>
                <p class="text-gray-700">
                    The highest governing body of MACDEF, consisting of representation of all member categories who have duly complied with requirements.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3">
                    <i class="ri-group-2-line mr-2"></i>The Board of Directors (BoD)
                </h3>
                <p class="text-gray-700">
                    Manages the business of the Company. Composed of a Chairperson, Secretary, and seven (07) members (minimum three members).
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3">
                    <i class="ri-briefcase-line mr-2"></i>The Secretariat
                </h3>
                <p class="text-gray-700">
                    Undertakes active day-to-day participation in Company affairs. Comprises the Executive Director, Heads of Thematic Clusters, and Administrative Team.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3">
                    <i class="ri-list-check-3 mr-2"></i>The Committees
                </h3>
                <p class="text-gray-700">
                    Thematic Committees formed under each Thematic Area. Members are elected by popular consensus from those with special expertise and interest.
                </p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="mt-16 bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white rounded-lg p-12 text-center">
        <h2 class="text-3xl font-bold mb-4">Help Us Achieve These Goals</h2>
        <p class="text-lg mb-8">Your support, participation, and engagement are vital to our success in preserving Ma'di heritage and fostering sustainable development.</p>
        <div class="flex justify-center gap-4">
            <a href="/contact" class="bg-white text-[#8B4513] px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
                Get Involved
            </a>
            <a href="/events" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-[#8B4513] transition">
                View Events
            </a>
        </div>
    </section>
</main>

@code {
    private List<string> GetTimelineItems(int phase)
    {
        return phase switch
        {
            1 => new List<string> { "Establish core infrastructure", "Launch language programs", "Document oral histories", "Build youth networks" },
            2 => new List<string> { "Open cultural centers", "Establish education partnerships", "Launch entrepreneur programs", "Increase community reach" },
            3 => new List<string> { "School curriculum integration", "International partnerships", "Research publications", "Global showcase events" },
            4 => new List<string> { "Self-sustaining programs", "Endowment establishment", "Legacy building", "Generational impact" },
            _ => new List<string>()
        };
    }
}
