@page "/mission"
@namespace MACDEF.Client.Pages

<div class="bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl font-bold mb-4">Mission, Vision & Core Values</h1>
        <p class="text-lg text-gray-100">Guiding principles of Ma'di Cultural and Development Foundation</p>
    </div>
</div>

<main class="max-w-4xl mx-auto py-16 px-6">
    <!-- Background Section -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-6 text-gray-900">Background</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-4">
            Ma'di Cultural and Development Foundation (MACDEF) was established in 2012 under the leadership of an Ad Hoc Committee as a body to mobilize and rally the Ma'di people
            to strive for socio-economic and cultural development of their land. The inaugural Ad Hoc Executive meeting was held on 16th May 2012.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed">
            Since its inception, MACDEF has engaged Ma'di communities across various parts of the country including Kampala, Entebbe, Jinja, Masindi, Arua, Moyo, Adjumani and beyond.
            The foundation has developed a robust framework that embraces the community on shared interests in the development of the Ma'di people and their region.
        </p>
    </section>

    <!-- Mission Section -->
    <section class="mb-16">
        <div class="flex gap-8 items-start mb-8">
            <div class="text-6xl text-[#8B4513] flex-shrink-0">
                <i class="ri-target-2-line"></i>
            </div>
            <div>
                <h2 class="text-4xl font-bold mb-6 text-gray-900">Our Mission</h2>
                <div class="mb-6">
                    <h3 class="text-2xl font-semibold text-gray-800 mb-3">Shorter Version:</h3>
                    <p class="text-lg text-gray-700 leading-relaxed">
                        To provide a framework for harnessing and promoting the rich and unique cultural, social and economic potentials and rich heritage of the Ma'di people
                        for achieving prosperity and sustainable development.
                    </p>
                </div>
                <div>
                    <h3 class="text-2xl font-semibold text-gray-800 mb-3">Longer Version:</h3>
                    <p class="text-lg text-gray-700 leading-relaxed">
                        To be a strategic development catalyst set to build synergies with other development organizations and initiatives for socio-cultural and socio-economic
                        development of the Ma'di people through providing platform, mobilization of capital and empowerment of communities for engagement in strategic socio-cultural
                        and socio-economic development actions, and provision of stewardship for advocacy on equitable development of the Ma'di people.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Vision Section -->
    <section class="mb-16">
        <div class="flex gap-8 items-start mb-8 flex-row-reverse">
            <div class="text-6xl text-[#D2691E] flex-shrink-0">
                <i class="ri-lightbulb-flash-line"></i>
            </div>
            <div>
                <h2 class="text-4xl font-bold mb-6 text-gray-900">Our Vision</h2>
                <p class="text-lg text-gray-700 leading-relaxed">
                    A culturally, socially and economically prosperous cohesive Ma'di that derives capital and pride from its rich heritage and peaceful geo-cosmopolitan co-existence.
                </p>
            </div>
        </div>
    </section>

    <!-- Core Values -->
    <section class="bg-gray-100 rounded-lg p-12 mb-16">
        <h2 class="text-4xl font-bold mb-12 text-center text-gray-900">Core Values</h2>
        <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-heart-fill mr-3"></i> God Loving
                </h3>
                <p class="text-gray-700">
                    We are rooted in spiritual principles and faith-based values that guide our actions and mission.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-award-fill mr-3"></i> Commitment & Dedication
                </h3>
                <p class="text-gray-700">
                    We are dedicated to the preservation and development of Ma'di culture with unwavering commitment.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-checkbox-circle-fill mr-3"></i> Honesty & Sincerity
                </h3>
                <p class="text-gray-700">
                    We operate with transparency and integrity in all our dealings and interactions.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-focus-2-fill mr-3"></i> Diligence
                </h3>
                <p class="text-gray-700">
                    We demonstrate careful, thorough attention to detail in all our work and initiatives.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-balance-line mr-3"></i> Fairness & Equality
                </h3>
                <p class="text-gray-700">
                    We promote equity and fair treatment for all members of the Ma'di community.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-hand-heart-fill mr-3"></i> Mutual Respect
                </h3>
                <p class="text-gray-700">
                    We respect the dignity, heritage, and perspectives of all members of our community.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-book-open-fill mr-3"></i> Knowledge Sharing
                </h3>
                <p class="text-gray-700">
                    We actively promote the sharing and dissemination of knowledge and cultural information.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-2xl font-bold text-[#8B4513] mb-3 flex items-center">
                    <i class="ri-leaf-fill mr-3"></i> Respect for Ma'di Culture
                </h3>
                <p class="text-gray-700">
                    We deeply respect and celebrate the unique cultural heritage and traditions of the Ma'di people.
                </p>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="text-center">
        <h2 class="text-3xl font-bold mb-6 text-gray-900">Join Our Mission</h2>
        <p class="text-lg text-gray-700 mb-8">
            Be part of a community dedicated to preserving and celebrating Ma'di heritage and fostering sustainable development.
        </p>
        <div class="flex justify-center gap-4">
            <a href="/contact" class="bg-[#8B4513] text-white px-8 py-3 rounded-lg font-semibold hover:bg-[#A0522D] transition">
                Get Involved
            </a>
            <a href="/goals" class="border-2 border-[#8B4513] text-[#8B4513] px-8 py-3 rounded-lg font-semibold hover:bg-[#8B4513] hover:text-white transition">
                Our Goals
            </a>
        </div>
    </section>
</main>

