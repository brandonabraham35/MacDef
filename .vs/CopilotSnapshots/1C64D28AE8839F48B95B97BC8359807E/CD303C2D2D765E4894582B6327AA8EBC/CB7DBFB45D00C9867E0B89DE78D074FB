@page "/admin/contact-submissions"
@namespace MACDEF.Client.Pages
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Contact Submissions - MACDEF</PageTitle>

<section class="bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white py-16">
    <div class="max-w-5xl mx-auto px-6 text-center">
        <h1 class="text-4xl font-bold mb-4">Contact Submissions</h1>
        <p class="text-lg text-gray-100">Saved messages submitted through the website</p>
    </div>
</section>

<main class="max-w-6xl mx-auto py-16 px-6">
    @if (string.IsNullOrWhiteSpace(adminSecret))
    {
        <div class="bg-white rounded-lg shadow-md p-8 max-w-xl mx-auto">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Admin Access</h2>
            <p class="text-gray-700 mb-4">Enter the shared secret to view contact submissions.</p>
            <p class="text-sm text-gray-500 mb-4">Use the same value configured in AdminAccess:Secret.</p>
            <input @bind="adminSecret" type="password" class="w-full px-4 py-2 border rounded-lg mb-4" placeholder="Admin secret" />
            <button class="bg-[#8B4513] text-white px-4 py-2 rounded-lg hover:bg-[#A0522D] transition" @onclick="LoadAsync">Unlock</button>
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="mt-4 bg-red-100 text-red-800 rounded-lg p-4">@errorMessage</div>
            }
        </div>
    }
    else
    {
        @if (loading)
        {
            <div class="text-center py-12 text-gray-600">Loading submissions...</div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="bg-red-100 text-red-800 rounded-lg p-4 max-w-xl mx-auto">@errorMessage</div>
        }
        else if (submissions.Count == 0)
        {
            <div class="bg-white rounded-lg shadow-md p-8 text-center text-gray-600">
                No submissions have been received yet.
            </div>
        }
        else
        {
            <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <div class="p-4 border-b flex items-center justify-between gap-4 flex-wrap">
                    <h2 class="text-2xl font-bold text-gray-900">Recent Messages</h2>
                    <button class="bg-[#8B4513] text-white px-4 py-2 rounded-lg hover:bg-[#A0522D] transition" @onclick="LoadAsync">Refresh</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead class="bg-gray-100 text-gray-700">
                            <tr>
                                <th class="text-left p-3">Date</th>
                                <th class="text-left p-3">Name</th>
                                <th class="text-left p-3">Email</th>
                                <th class="text-left p-3">Subject</th>
                                <th class="text-left p-3">Phone</th>
                                <th class="text-left p-3">Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in submissions)
                            {
                                <tr class="border-t align-top">
                                    <td class="p-3 whitespace-nowrap">@item.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="p-3 whitespace-nowrap">@item.FirstName @item.LastName</td>
                                    <td class="p-3 whitespace-nowrap">@item.Email</td>
                                    <td class="p-3 whitespace-nowrap">@item.Subject</td>
                                    <td class="p-3 whitespace-nowrap">@item.Phone</td>
                                    <td class="p-3 max-w-xl">@item.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</main>

@code {
    private List<ContactSubmissionDto> submissions = [];
    private bool loading = true;
    private string? errorMessage;
    private string? adminSecret;

    private async Task LoadAsync()
    {
        if (string.IsNullOrWhiteSpace(adminSecret))
        {
            errorMessage = "Admin secret is required.";
            return;
        }

        loading = true;
        errorMessage = null;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "api/contact-submissions");
            request.Headers.Add("X-MACDEF-Admin-Key", adminSecret);

            var response = await Http.SendAsync(request);
            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Invalid admin secret or admin access is not configured on the server.";
                submissions = [];
                return;
            }

            response.EnsureSuccessStatusCode();
            submissions = await response.Content.ReadFromJsonAsync<List<ContactSubmissionDto>>() ?? [];
        }
        catch
        {
            errorMessage = "Unable to load contact submissions.";
        }
        finally
        {
            loading = false;
        }
    }

    public class ContactSubmissionDto
    {
        public string Id { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Phone { get; set; }
        public string Subject { get; set; } = "";
        public string Message { get; set; } = "";
        public DateTimeOffset CreatedUtc { get; set; }
    }
}
