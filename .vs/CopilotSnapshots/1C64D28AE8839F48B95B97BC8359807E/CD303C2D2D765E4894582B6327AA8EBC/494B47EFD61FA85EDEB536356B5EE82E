using System.Net;
using System.Net.Mail;
using MACDEF.Shared;
using Microsoft.AspNetCore.Mvc;
using Microsoft.Extensions.Options;

namespace MACDEF.Controllers;

[ApiController]
[Route("api")]
[IgnoreAntiforgeryToken]
public sealed class ContactController : ControllerBase
{
    private readonly ContactSubmissionStore store;
    private readonly IOptions<SmtpOptions> smtpOptions;
    private readonly IOptions<AdminAccessOptions> adminOptions;
    private readonly ILogger<ContactController> logger;

    public ContactController(
        ContactSubmissionStore store,
        IOptions<SmtpOptions> smtpOptions,
        IOptions<AdminAccessOptions> adminOptions,
        ILogger<ContactController> logger)
    {
        this.store = store;
        this.smtpOptions = smtpOptions;
        this.adminOptions = adminOptions;
        this.logger = logger;
    }

    [HttpOptions("contact")]
    public IActionResult ContactOptions() => NoContent();

    [HttpPost("contact")]
    public async Task<IActionResult> SubmitContact([FromBody] ContactSubmissionRequest request)
    {
        var errors = Validate(request);
        if (errors.Count > 0)
        {
            return BadRequest(errors);
        }

        logger.LogInformation("Contact submission received from {FirstName} {LastName} <{Email}> with subject {Subject}", request.FirstName, request.LastName, request.Email, request.Subject);

        var entry = new ContactSubmissionEntry(
            Guid.NewGuid().ToString("N"),
            request.FirstName,
            request.LastName,
            request.Email,
            request.Phone,
            request.Subject,
            request.Message,
            DateTimeOffset.UtcNow);

        await store.AddAsync(entry);

        var options = smtpOptions.Value;
        if (options.IsConfigured)
        {
            try
            {
                using var message = new MailMessage();
                message.From = new MailAddress(options.FromAddress!);
                message.To.Add(options.ToAddress!);
                message.ReplyToList.Add(new MailAddress(request.Email));
                message.Subject = $"MACDEF Website Inquiry: {request.Subject}";
                message.Body = BuildEmailBody(request);
                message.IsBodyHtml = false;

                using var client = new SmtpClient(options.Host!, options.Port)
                {
                    EnableSsl = options.UseSsl,
                    Credentials = string.IsNullOrWhiteSpace(options.Username)
                        ? CredentialCache.DefaultNetworkCredentials
                        : new NetworkCredential(options.Username, options.Password)
                };

                await client.SendMailAsync(message);
                return Ok(new ContactSubmissionResponse(true, "Thank you for reaching out! Your message has been sent successfully."));
            }
            catch (Exception ex)
            {
                logger.LogWarning(ex, "SMTP delivery failed; submission was saved locally.");
                return Ok(new ContactSubmissionResponse(true, "Thank you for reaching out! Your message was received and saved for follow-up."));
            }
        }

        return Ok(new ContactSubmissionResponse(true, "Thank you for reaching out! Your message was received and saved for follow-up."));
    }

    [HttpGet("contact-submissions")]
    public async Task<IActionResult> GetSubmissions()
    {
        if (!IsAdminAuthorized(Request))
        {
            return Unauthorized();
        }

        return Ok(await store.GetAllAsync());
    }

    private bool IsAdminAuthorized(HttpRequest request)
    {
        var options = adminOptions.Value;
        if (!options.IsConfigured)
        {
            return false;
        }

        if (!request.Headers.TryGetValue(options.HeaderName, out var provided))
        {
            return false;
        }

        return string.Equals(provided.ToString(), options.Secret, StringComparison.Ordinal);
    }

    private static Dictionary<string, string[]> Validate(ContactSubmissionRequest request)
    {
        var errors = new Dictionary<string, string[]>();

        void Add(string key, string message) => errors[key] = [message];

        if (string.IsNullOrWhiteSpace(request.FirstName)) Add(nameof(request.FirstName), "First name is required.");
        if (string.IsNullOrWhiteSpace(request.LastName)) Add(nameof(request.LastName), "Last name is required.");
        if (string.IsNullOrWhiteSpace(request.Email)) Add(nameof(request.Email), "Email is required.");
        if (string.IsNullOrWhiteSpace(request.Subject)) Add(nameof(request.Subject), "Subject is required.");
        if (string.IsNullOrWhiteSpace(request.Message) || request.Message.Length < 10) Add(nameof(request.Message), "Message must be at least 10 characters.");

        return errors;
    }

    private static string BuildEmailBody(ContactSubmissionRequest request)
    {
        return $"Name: {request.FirstName} {request.LastName}{Environment.NewLine}Email: {request.Email}{Environment.NewLine}Phone: {request.Phone}{Environment.NewLine}Subject: {request.Subject}{Environment.NewLine}{Environment.NewLine}Message:{Environment.NewLine}{request.Message}";
    }
}
