@page "/goals"
@namespace MACDEF.Client.Pages

<div class="bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl font-bold mb-4">Our Goals</h1>
        <p class="text-lg text-gray-100">Strategic objectives for cultural preservation and community development</p>
    </div>
</div>

<main class="max-w-4xl mx-auto py-16 px-6">
    <div class="mb-12">
        <p class="text-lg text-gray-700 text-center">
            MACDEF is committed to achieving ambitious goals that strengthen our cultural heritage and empower our community for sustainable development.
        </p>
    </div>

    <!-- Goals Grid -->
    <div class="grid md:grid-cols-2 gap-8">
        <GoalCard 
            Number="01" 
            Title="Language Preservation" 
            Description="Establish language learning programs and create comprehensive Madi language documentation to ensure younger generations can speak, read, and write in our native language." />

        <GoalCard 
            Number="02" 
            Title="Cultural Documentation" 
            Description="Create a comprehensive archive of Madi cultural knowledge, oral histories, traditional practices, and artistic expressions for preservation and educational purposes." />

        <GoalCard 
            Number="03" 
            Title="Youth Empowerment" 
            Description="Develop mentorship programs, leadership training, and skill-building initiatives that empower young Madi people to become advocates for cultural preservation." />

        <GoalCard 
            Number="04" 
            Title="Community Infrastructure" 
            Description="Establish cultural centers and community spaces where traditional practices, arts, and knowledge can be taught, practiced, and celebrated." />

        <GoalCard 
            Number="05" 
            Title="Economic Development" 
            Description="Support traditional artisans and cultural entrepreneurs through training, resources, and market access to create sustainable economic opportunities." />

        <GoalCard 
            Number="06" 
            Title="Educational Integration" 
            Description="Work with schools and institutions to integrate Madi cultural content into educational curricula, fostering pride and understanding among youth." />

        <GoalCard 
            Number="07" 
            Title="International Recognition" 
            Description="Showcase Madi culture on global platforms through exhibitions, performances, and cultural exchange programs that celebrate our heritage worldwide." />

        <GoalCard 
            Number="08" 
            Title="Health & Wellness" 
            Description="Promote traditional healing practices, wellness knowledge, and holistic approaches to health within the context of modern medical advancement." />
    </div>

    <!-- Timeline Section -->
    <section class="mt-16">
        <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">Implementation Timeline</h2>
        <div class="space-y-8">
            <TimelineItem 
                Year="2024-2025" 
                Title="Foundation Phase" 
                Items="GetTimelineItems(1)" />

            <TimelineItem 
                Year="2025-2026" 
                Title="Expansion Phase" 
                Items="GetTimelineItems(2)" />

            <TimelineItem 
                Year="2026-2027" 
                Title="Integration Phase" 
                Items="GetTimelineItems(3)" />

            <TimelineItem 
                Year="2027-2028" 
                Title="Sustainability Phase" 
                Items="GetTimelineItems(4)" />
        </div>
    </section>

    <!-- CTA Section -->
    <section class="mt-16 bg-gradient-to-r from-[#8B4513] to-[#D2691E] text-white rounded-lg p-12 text-center">
        <h2 class="text-3xl font-bold mb-4">Help Us Achieve These Goals</h2>
        <p class="text-lg mb-8">Your support, participation, and engagement are vital to our success.</p>
        <div class="flex justify-center gap-4">
            <a href="/contact" class="bg-white text-[#8B4513] px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
                Get Involved
            </a>
            <a href="/donate" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-[#8B4513] transition">
                Support Us
            </a>
        </div>
    </section>
</main>

